# --- Authentication (WebAuthn + JWT sessions) ---
# Random 32+ character secret used to sign session and challenge JWTs.
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# WebAuthn Relying Party config. For local dev the defaults below work as-is.
# In production set these to your deployed domain.
RP_ID=localhost
RP_NAME=Todo App
RP_ORIGIN=http://localhost:3000

# --- Database ---
# Optional explicit path to the SQLite file. Defaults to ./todos.db locally,
# or $RAILWAY_VOLUME_MOUNT_PATH/todos.db when deployed on Railway with a volume.
# DATABASE_PATH=/app/data/todos.db
